{
  "name": "md-to-image-service",
  "version": "1.0.7",
  "description": "本地 Markdown 转图片 Web 工具",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:bundle": "esbuild server.js --bundle --platform=node --format=cjs --outfile=dist/server.bundle.js",
    "build:sea": "node --experimental-sea-config sea-config.json",
    "build:exe": "node scripts/build-exe.js",
    "build": "npm run build:bundle && npm run build:sea && npm run build:exe"
  },
  "dependencies": {
    "express": "^4.18.2",
    "marked": "^12.0.0",
    "multer": "^1.4.5-lts.1",
    "puppeteer-core": "^22.0.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.19.0",
    "esbuild": "^0.28.0"
  }
}
